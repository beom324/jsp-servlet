<%@page import="com.sist.vo.BookVO"%>
<%@page import="java.util.ArrayList"%>
<%@page import="com.sist.vo.DeptVO"%>
<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
<%
	String title = (String)session.getAttribute("title");
	//int year = (int)session.getAttribute("year");
	int []data = (int[])session.getAttribute("data");
	DeptVO d =(DeptVO)session.getAttribute("d");
	ArrayList<BookVO> list = (ArrayList<BookVO>)session.getAttribute("list");
%>

<h2>변수에 저장한 값 확인</h2>
<hr>
title : <%=title %><br>
year : <%=year %><br>
data : <%=data %><br>

<%
	for(int v:data){
		out.print(v+"\n");
	}
%>
<hr>
부서번호 : <%=d.getDno() %> <br>
부서명 : <%=d.getdName() %><br>
부서위치 : <%=d.getdLoc() %><br>

<hr>
<h2>도서목록</h2>
<%
	for(BookVO v:list){
		%>
		
		도서번호 : <%=v.getBookId() %><br>
		도서명 : <%=v.getBookName() %><br>
		가격 : <%=v.getPrice() %><br>
		출판사 : <%=v.getPublisher() %><br>
		
		
		
		<%
	}
%>

</body>
</html>