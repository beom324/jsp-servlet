<%@page import="com.sist.dao.GoodsDAO"%>
<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
<%
	request.setCharacterEncoding("utf-8");
%>
<jsp:useBean id="goods" class="com.sist.vo.GoodsVO"></jsp:useBean>
<jsp:useBean id="dao" class="com.sist.dao.GoodsDAO"></jsp:useBean>
<jsp:setProperty property="*" name="goods" />
<%
	int re = dao.insertGoods(goods);
	if(re==1){
		System.out.print("상품이 등록되었습니다");
	}else{
		System.out.print("상품 등록에 실패했습니다");
	}
%>
<a href="insertGoods.jsp"> 상품 등록</a>
<a href="listGoods.jsp"> 상품 목록</a>
</body>
</html>